<!--
  views/error.etlua — Error page template
  Rendered by controllers/error.lua for the "/error" route.
  Safe fallback for error_code if not provided.
-->
<div class="error-container">
  <h1>Oops!</h1>

  <p class="error-code">Error: <strong><%= error_code or "unknown_error" %></strong></p>

  <p class="error-description">Something went wrong. Please try again or return to the home page.</p>

  <a href="<%- req:build_url() %>" class="btn">&larr; Back to Home</a>
</div>
