<!--
  views/index.etlua — Home page template
  Rendered by controllers/index.lua for the "/" route.
  Displays a welcome message and a brief site description.
-->
<h1><%= welcome_message or "Welcome to Stadius" %></h1>

<p class="lead"><%= description or "" %></p>

<div class="home-links">
  <a href="<%- build_url() %>/articles" class="btn">Browse Articles</a>
  <a href="<%- build_url() %>/login" class="btn btn-secondary">Login</a>
</div>
